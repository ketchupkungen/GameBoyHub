<Window x:Class="GameBoyHub.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameBoy Hub"
        Height="700"
        Width="1000"
        Background="#202020">

    <Grid>
        <Border Background="#2D2D2D" Padding="16">
            <StackPanel>
                <TextBlock Text="GameBoy Hub"
                           FontSize="22"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Double-click a game to open it in its own window"
                           Foreground="#C7D2FE"
                           Margin="0,0,0,8"/>

                <ListBox x:Name="GamesList"
                         DisplayMemberPath="Title"
                         MouseDoubleClick="GamesList_MouseDoubleClick"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>