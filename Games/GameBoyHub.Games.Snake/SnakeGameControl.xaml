<!--
    File: SnakeGameControl.xaml
    Purpose: Defines the visual layout for the Snake game UI. This XAML
    declares the game canvas, overlays for the start and game-over screens,
    and UI controls for Play, Restart and simple placeholders for difficulty
    and grid size configuration.
-->
<UserControl x:Class="GameBoyHub.Games.Snake.SnakeGameControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="UserControl_Loaded"
             KeyDown="UserControl_KeyDown">
    <Grid Background="#1B1B25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,12"
                Padding="14"
                Background="#252538"
                CornerRadius="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">
                    <TextBlock Text="Snake"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#F3F4F6"
                               Margin="0,0,16,0"/>
                    <TextBlock Text="Score: "
                               FontSize="16"
                               Foreground="#C7D2FE"/>
                    <TextBlock x:Name="ScoreTextBlock"
                               Text="0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#86EFAC"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock
                        HorizontalAlignment="Right"
                        Text="Arrows / WASD · R = restart · P = pause"
                        FontSize="13"
                        Foreground="#A1A1AA"/>
                    <TextBlock x:Name="PauseIndicator"
                               HorizontalAlignment="Right"
                               Text=""
                               FontSize="13"
                               Foreground="#FACC15"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="20,0,20,20">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="12"
                    Background="#252538"
                    CornerRadius="12">
                <Grid>
                    <Canvas x:Name="GameCanvas"
                            Width="480"
                            Height="480"
                            Background="#2B2B44"/>

                    <Border x:Name="OverlayPanel"
                            Width="480"
                            Height="480"
                            Background="#880E0E14"
                            Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Game Over"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="OverlayScoreTextBlock"
                                       Margin="0,10,0,0"
                                       FontSize="18"
                                       Foreground="#D4D4D8"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Press R or Enter to restart"
                                       Margin="0,10,0,0"
                                       FontSize="15"
                                       Foreground="#A1A1AA"
                                       HorizontalAlignment="Center"/>
                            <Button x:Name="RestartButton"
                                    Content="Restart"
                                    Margin="0,12,0,0"
                                    Padding="8"
                                    Click="RestartButton_Click"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Start panel shown initially; user presses Play to begin -->
                    <Border x:Name="StartPanel"
                            Width="480"
                            Height="480"
                            Background="#DD101010"
                            Visibility="Visible">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Width="300">
                            <TextBlock Text="Snake"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>

                            <Button x:Name="PlayButton"
                                    Content="Play"
                                    FontSize="18"
                                    Padding="10"
                                    Click="PlayButton_Click"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,12"/>

                            <TextBlock Text="Difficulty"
                                       Foreground="#D4D4D8"
                                       Margin="0,6,0,0"/>
                            <Slider x:Name="DifficultySlider"
                                    Minimum="1"
                                    Maximum="3"
                                    Value="2"
                                    IsSnapToTickEnabled="True"
                                    TickFrequency="1"/>

                            <TextBlock Text="Grid Size"
                                       Foreground="#D4D4D8"
                                       Margin="0,6,0,0"/>
                            <Slider x:Name="GridSizeSlider"
                                    Minimum="10"
                                    Maximum="30"
                                    Value="20"
                                    IsSnapToTickEnabled="True"
                                    TickFrequency="2"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
